            <Button fx:id="btnAgregar" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Agregar" GridPane.columnIndex="1" />
            <CheckBox fx:id="checkLista" mnemonicParsing="false" text="Ver lista" GridPane.columnIndex="3">
