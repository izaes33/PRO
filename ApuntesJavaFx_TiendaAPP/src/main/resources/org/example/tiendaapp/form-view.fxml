            </TextField>
            <Spinner fx:id="spinnerEdad" maxWidth="1.7976931348623157E308" GridPane.rowIndex="5" />
            <ChoiceBox fx:id="comboTipo" maxWidth="1.7976931348623157E308"  GridPane.rowIndex="6" />
            <HBox alignment="CENTER_RIGHT" prefHeight="100.0" prefWidth="200.0" spacing="20.0" GridPane.rowIndex="7">
               <children>
                  <RadioButton fx:id="radioMasc" mnemonicParsing="false" text="Masculino">
                     <cursor>
                        <Cursor fx:constant="HAND" />
