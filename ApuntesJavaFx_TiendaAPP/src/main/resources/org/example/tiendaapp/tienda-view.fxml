<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.tiendaapp.controller.TiendaController">
    <center>
        <TableView fx:id="tablaProductos" prefHeight="200.0" prefWidth="200.0" tableMenuButtonVisible="true" BorderPane.alignment="CENTER">
            <columns>
                <TableColumn fx:id="columnaNombre" prefWidth="75.0" text="Nombre" />
                <TableColumn fx:id="columnaPrecio" prefWidth="75.0" text="Precio" />
                <TableColumn fx:id="columnaStock" prefWidth="75.0" text="Stock" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </center>
    <top>
        <TextField fx:id="editFiltro" BorderPane.alignment="CENTER" promptText="Buscar producto..." />
    </top>
    <bottom>
        <GridPane BorderPane.alignment="CENTER">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            </rowConstraints>
            <children>
                <Button fx:id="btnCompra" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Comprar" />
                <Button fx:id="btnDetalle" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Detalle" GridPane.columnIndex="1" />
                <Button fx:id="btnCarrito" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Ver carrito" GridPane.columnIndex="2" />
                <Button fx:id="btnCerrar" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Cerrar sesión" GridPane.columnIndex="3" />
            </children>
        </GridPane>
    </bottom>
</BorderPane>